# Production environment for chainproof.rejoda.co.tz
# Copy to backend/.env on the server and fill secrets.
#
# IMPORTANT:
# - DATABASE_URL: URL-encode special chars in password (@ → %40)
# - TENANT_DB_PASSWORD: use the RAW password (NOT URL-encoded)

PORT=8080
ENV=production
DATABASE_URL=postgres://postgres:CHANGE_ME@127.0.0.1:5432/chainproof_platform?sslmode=disable
TENANT_DB_HOST=127.0.0.1
TENANT_DB_PORT=5432
TENANT_DB_USER=postgres
TENANT_DB_PASSWORD=CHANGE_ME
JWT_SECRET=CHANGE_ME
JWT_EXPIRY_HOURS=24
FABRIC_GATEWAY_URL=http://127.0.0.1:8091
FABRIC_GATEWAY_API_KEY=chainproof-dev-key
FABRIC_DEV_MOCK=false
SEED_ADMIN_EMAIL=admin@chainproof.io
SEED_ADMIN_PASSWORD=CHANGE_ME
CORS_ORIGINS=https://chainproof.rejoda.co.tz
APP_URL=https://chainproof.rejoda.co.tz

# Stripe (optional — leave empty until ready)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Mail (optional)
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=
MAIL_ENCRYPTION=tls
